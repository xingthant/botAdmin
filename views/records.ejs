<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Records — Systems Analytics Hub</title>
    <style>
        :root {
            --bg-main: #09090b;
            --bg-card: #141416;
            --bg-input: #1d1d21;
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --success: #10b981;
            --success-bg: rgba(16, 185, 129, 0.1);
            --success-text: #34d399;
            --danger: #ef4444;
            --danger-bg: rgba(239, 68, 68, 0.1);
            --danger-text: #fca5a5;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: #27272a;
            --radius-lg: 14px;
            --radius-md: 10px;
            --radius-sm: 6px;
            --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
            --font-stack: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-stack);
            background-color: var(--bg-main);
            color: var(--text-main);
            padding: 40px 20px;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 1440px;
            margin: 0 auto;
        }

        .navbar {
            background: var(--bg-card);
            padding: 24px 32px;
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .nav-left {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .nav-left h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            letter-spacing: -0.02em;
        }

        .nav-meta {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
        }

        .back-link {
            color: var(--primary);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

        .back-link:hover {
            color: var(--primary-hover);
        }

        .record-count {
            color: var(--text-muted);
            background: #1e1e22;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 18px;
            border: 1px solid transparent;
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }
        .btn-primary:hover {
            background: var(--primary-hover);
        }

        .btn-secondary {
            background: var(--bg-input);
            border-color: var(--border-color);
            color: #e2e8f0;
        }
        .btn-secondary:hover {
            background: #27272a;
            border-color: #3f3f46;
        }

        .btn-danger {
            background: var(--danger-bg);
            color: var(--danger-text);
            border-color: rgba(239, 68, 68, 0.2);
        }
        .btn-danger:hover {
            background: rgba(239, 68, 68, 0.2);
        }

        .logout-btn {
            padding: 10px 18px;
            background: var(--danger-bg);
            color: var(--danger-text);
            border-radius: var(--radius-sm);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.2s;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }
        .logout-btn:hover {
            background: rgba(239, 68, 68, 0.2);
        }

        .search-section {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
            background: var(--bg-card);
            padding: 24px;
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-color);
            align-items: center;
        }

        .search-input-wrapper {
            flex: 1;
            min-width: 280px;
            position: relative;
        }

        .search-section input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            font-size: 14px;
            background-color: var(--bg-main);
            color: var(--text-main);
            transition: all 0.2s;
        }

        .search-section input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
        }

        .search-section select {
            padding: 12px 16px;
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            font-size: 14px;
            background: var(--bg-main);
            color: var(--text-main);
            min-width: 160px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .search-section select:focus {
            outline: none;
            border-color: var(--primary);
        }

        .table-container {
            background: var(--bg-card);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-color);
            overflow: hidden;
            margin-bottom: 24px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th {
            background: #18181b;
            padding: 16px 24px;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--border-color);
            cursor: pointer;
            user-select: none;
            transition: background 0.2s;
        }

        th:hover {
            background: #27272a;
        }

        th .sort-icon {
            margin-left: 4px;
            color: #71717a;
        }

        td {
            padding: 18px 24px;
            border-bottom: 1px solid var(--border-color);
            font-size: 14px;
            color: #e2e8f0;
            vertical-align: middle;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background-color: #1a1a1e;
        }

        .account-primary {
            font-weight: 600;
            color: var(--text-main);
        }

        .account-secondary {
            font-weight: 500;
            color: #818cf8;
        }

        .deposit-today {
            color: #34d399;
            font-weight: 600;
        }

        .deposit-month {
            color: #38bdf8;
            font-weight: 600;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
            line-height: 1;
        }

        .badge-success {
            background: var(--success-bg);
            color: var(--success-text);
        }

        .badge-danger {
            background: var(--danger-bg);
            color: var(--danger-text);
        }

        .action-cell {
            display: flex;
            gap: 8px;
        }

        .btn-icon {
            background: var(--bg-main);
            border: 1px solid var(--border-color);
            font-size: 14px;
            cursor: pointer;
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--radius-sm);
            transition: all 0.2s;
            color: #cbd5e1;
        }

        .btn-icon:hover {
            transform: translateY(-1px);
        }

        .btn-icon.edit:hover {
            color: var(--primary);
            border-color: var(--primary);
            background: rgba(99, 102, 241, 0.1);
        }

        .btn-icon.delete:hover {
            color: #ef4444;
            border-color: #ef4444;
            background: var(--danger-bg);
        }

        .truncate {
            max-width: 140px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            display: inline-block;
        }

        .pagination {
            display: flex;
            gap: 6px;
            justify-content: center;
            align-items: center;
            margin-top: 32px;
        }

        .page-btn {
            padding: 8px 14px;
            border: 1px solid var(--border-color);
            background: var(--bg-card);
            color: #e2e8f0;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .page-btn:hover:not(:disabled) {
            background: #27272a;
            border-color: #52525b;
        }

        .page-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .page-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(5px);
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: var(--bg-card);
            padding: 32px;
            border-radius: var(--radius-lg);
            max-width: 600px;
            width: 90%;
            max-height: 85vh;
            overflow-y: auto;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border-color);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--border-color);
        }

        .modal-header h2 {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: -0.01em;
            color: var(--text-main);
        }

        .modal-close {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            color: var(--text-muted);
            transition: color 0.2s;
        }
        .modal-close:hover {
            color: var(--text-main);
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 6px;
            color: #cbd5e1;
            font-weight: 600;
            font-size: 13px;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            font-size: 14px;
            background: var(--bg-main);
            color: var(--text-main);
            transition: border-color 0.2s;
            font-family: inherit;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 28px;
            padding-top: 20px;
            border-top: 1px solid var(--border-color);
        }

        .form-actions .btn {
            flex: 1;
        }

        .notification {
            position: fixed;
            bottom: 24px;
            right: 24px;
            padding: 16px 24px;
            border-radius: var(--radius-md);
            color: white;
            font-weight: 600;
            font-size: 14px;
            z-index: 2000;
            box-shadow: var(--shadow-lg);
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes slideUp {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .notification.success { background: var(--success); color: #fff; }
        .notification.error { background: var(--danger); color: #fff; }
        .notification.info { background: var(--primary); color: #fff; }

        .empty-state {
            text-align: center;
            padding: 64px 24px;
        }

        .empty-state .icon {
            font-size: 40px;
            margin-bottom: 12px;
            color: #4b5563;
        }

        .empty-state p {
            color: var(--text-muted);
            font-size: 15px;
        }

        @media (max-width: 1024px) {
            body { padding: 20px 12px; }
            td, th { padding: 14px 16px; }
        }

        @media (max-width: 768px) {
            .navbar { flex-direction: column; align-items: stretch; padding: 20px; }
            .nav-right { width: 100%; display: grid; grid-template-columns: 1fr 1fr; }
            .search-section { flex-direction: column; align-items: stretch; }
            .form-row { grid-template-columns: 1fr; gap: 0; }
        }
    </style>
</head>
<body>
    <div class="container">
        <nav class="navbar">
            <div class="nav-left">
                <h2>All Records</h2>
                <div class="nav-meta">
                    <a href="/dashboard" class="back-link">← Dashboard Overview</a>
                    <span class="record-count" id="recordCount">Processing analytics...</span>
                </div>
            </div>
            <div class="nav-right">
                <button class="btn btn-primary" onclick="openAddModal()">➕ Add New Record</button>
                <button class="btn btn-secondary" onclick="exportCSV()">📥 CSV</button>
                <button class="btn btn-secondary" onclick="exportJSON()">📄 JSON</button>
                <a href="/logout" class="logout-btn">🚪 Logout</a>
            </div>
        </nav>

        <div class="search-section">
            <div class="search-input-wrapper">
                <input type="text" id="searchInput" placeholder="Search by Ws Account, Platform, Receptionist, Developer, or Sender..." 
                       onkeypress="if(event.key==='Enter') searchRecords()">
            </div>
            <select id="searchField">
                <option value="all">All Fields</option>
                <option value="platformAccount">平台账号</option>
                <option value="wsAccount">Ws账号</option>
                <option value="receptionist">推接待</option>
                <option value="developer">开发</option>
                <option value="senderName">Sender</option>
            </select>
            <button class="btn btn-primary" onclick="searchRecords()">Apply Filters</button>
            <button class="btn btn-secondary" onclick="resetSearch()">Reset</button>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th onclick="sortTable('index')"># <span class="sort-icon">↕</span></th>
                        <th onclick="sortTable('wsAccount')">Ws账号 <span class="sort-icon">↕</span></th>
                        <th onclick="sortTable('platformAccount')">平台/会员账号 <span class="sort-icon">↕</span></th>
                        <th onclick="sortTable('receptionist')">推接待 <span class="sort-icon">↕</span></th>
                        <th onclick="sortTable('ipStatus')">IP状态 <span class="sort-icon">↕</span></th>
                        <th onclick="sortTable('joinDate')">进粉日期 <span class="sort-icon">↕</span></th>
                        <th onclick="sortTable('todayDeposit')">今日首存 <span class="sort-icon">↕</span></th>
                        <th onclick="sortTable('monthDeposit')">本月首存 <span class="sort-icon">↕</span></th>
                        <th onclick="sortTable('developer')">开发 <span class="sort-icon">↕</span></th>
                        <th onclick="sortTable('senderName')">Sender <span class="sort-icon">↕</span></th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="recordsBody">
                    <tr>
                        <td colspan="11" style="text-align:center;">
                            <div class="empty-state">
                                <div class="icon">🔄</div>
                                <p>Syncing table architecture components...</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="pagination" id="pagination"></div>
    </div>

    <div id="recordModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="modalTitle">Add New Record</h2>
                <button class="modal-close" onclick="closeModal()">✕</button>
            </div>
            <form id="recordForm" onsubmit="saveRecord(event)">
                <input type="hidden" id="editId" value="">
                
                <div class="form-group">
                    <label>Ws账号</label>
                    <input type="text" id="formWsAccount" placeholder="Enter Telegram/WhatsApp/Ws ID">
                </div>
                
                <div class="form-group">
                    <label>平台账号 / 会员账号 *</label>
                    <input type="text" id="formPlatformAccount" placeholder="Required system identifier" required>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>今日首存</label>
                        <input type="number" id="formTodayDeposit" placeholder="0" value="0" min="0">
                    </div>
                    <div class="form-group">
                        <label>本月首存</label>
                        <input type="number" id="formMonthDeposit" placeholder="0" value="0" min="0">
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>进粉日期</label>
                        <input type="text" id="formJoinDate" placeholder="e.g., 18/6 or 2026-07-07">
                    </div>
                    <div class="form-group">
                        <label>IP状态</label>
                        <select id="formIpStatus">
                            <option value="正常">✅ 正常 (Normal)</option>
                            <option value="异常">⚠️ 异常 (Anomaly Flag)</option>
                        </select>
                    </div>
                </div>
                
                <div class="form-group">
                    <label>开发</label>
                    <input type="text" id="formDeveloper" placeholder="Developer / Source Account Assignment">
                </div>
                
                <div class="form-group">
                    <label>推接待</label>
                    <input type="text" id="formReceptionist" placeholder="Receptionist handling name">
                </div>
                
                <div class="form-group">
                    <label>Sender Name</label>
                    <input type="text" id="formSenderName" placeholder="Admin/Bot Sender Label">
                </div>
                
                <div class="form-group">
                    <label>Raw Message Metadata Log</label>
                    <textarea id="formRawMessage" placeholder="Paste full system incoming transaction logging hooks string text details if applicable..." rows="3"></textarea>
                </div>
                
                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" onclick="closeModal()">Discard</button>
                    <button type="submit" class="btn btn-primary" id="saveBtn">Save Metrics</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        let currentPage = 1;
        let currentQuery = '';
        let currentField = 'all';
        const limit = 30;
        let totalRecords = 0;
        let sortField = '';
        let sortOrder = 'desc';
        let recordsCached = [];

        function showNotification(message, type = 'info') {
            const existing = document.querySelector('.notification');
            if (existing) existing.remove();
            
            const div = document.createElement('div');
            div.className = `notification ${type}`;
            div.textContent = message;
            document.body.appendChild(div);
            
            setTimeout(() => {
                div.style.opacity = '0';
                div.style.transform = 'translateY(10px)';
                div.style.transition = 'all 0.2s';
                setTimeout(() => div.remove(), 200);
            }, 4000);
        }

        function searchRecords() {
            const query = document.getElementById('searchInput').value.trim();
            const field = document.getElementById('searchField').value;
            currentQuery = query;
            currentField = field;
            
            if (!query) {
                loadRecords(1);
                return;
            }
            
            let url = `/api/search?q=${encodeURIComponent(query)}`;
            if (field !== 'all') url += `&field=${encodeURIComponent(field)}`;
            
            fetch(url)
                .then(res => res.json())
                .then(data => {
                    recordsCached = data.records || [];
                    renderRecords(recordsCached);
                    document.getElementById('pagination').innerHTML = '';
                    document.getElementById('recordCount').textContent = `${recordsCached.length} metrics captured`;
                })
                .catch(err => {
                    console.error(err);
                    showNotification('Search filtering pipeline connection dropped.', 'error');
                });
        }

        function resetSearch() {
            document.getElementById('searchInput').value = '';
            document.getElementById('searchField').value = 'all';
            currentQuery = '';
            currentField = 'all';
            loadRecords(1);
        }

        function loadRecords(page = 1) {
            currentPage = page;
            let url = `/api/records?page=${page}&limit=${limit}`;
            if (sortField) url += `&sort=${sortField}&order=${sortOrder}`;
            
            fetch(url)
                .then(res => res.json())
                .then(data => {
                    totalRecords = data.total;
                    recordsCached = data.records || [];
                    renderRecords(recordsCached);
                    renderPagination(data.total, data.page, data.totalPages);
                    document.getElementById('recordCount').textContent = `Total: ${data.total} records`;
                })
                .catch(err => {
                    console.error(err);
                    showNotification('Error refreshing relational matrix payload streams.', 'error');
                });
        }

        function renderRecords(records) {
            const tbody = document.getElementById('recordsBody');
            if (!records || records.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="11" style="text-align:center;">
                            <div class="empty-state">
                                <div class="icon">📭</div>
                                <p>No matching structured logs inside dashboard storage partition indexing parameters.</p>
                            </div>
                        </td>
                    </tr>`;
                return;
            }
            
            tbody.innerHTML = records.map((r, index) => {
                const startIndex = (currentPage - 1) * limit;
                const num = startIndex + index + 1;
                const isNormal = r.ipStatus && r.ipStatus.toLowerCase().includes('正常');
                const ipBadge = `<span class="badge ${isNormal ? 'badge-success' : 'badge-danger'}">${isNormal ? '✓ 正常' : '⚠ 异常'}</span>`;
                
                return `
                    <tr>
                        <td style="color: var(--text-muted); font-size:12px;">${num}</td>
                        <td class="account-primary">${r.wsAccount || '—'}</td>
                        <td class="account-secondary">${r.platformAccount || '—'}</td>
                        <td>${r.receptionist || '—'}</td>
                        <td>${ipBadge}</td>
                        <td><span style="font-weight:500;">${r.joinDate || '—'}</span></td>
                        <td class="deposit-today">¥${(r.todayDeposit || 0).toLocaleString()}</td>
                        <td class="deposit-month">¥${(r.monthDeposit || 0).toLocaleString()}</td>
                        <td><span class="truncate" title="${r.developer || ''}">${r.developer || '—'}</span></td>
                        <td><span class="badge" style="background:#27272a; color:#cbd5e1;">${r.senderName || '—'}</span></td>
                        <td>
                            <div class="action-cell">
                                <button class="btn-icon edit" onclick="fetchAndEditRecord('${r._id}')">✏️</button>
                                <button class="btn-icon delete" onclick="deleteRecord('${r._id}')">🗑️</button>
                            </div>
                        </td>
                    </tr>`;
            }).join('');
        }

        function renderPagination(total, currentPage, totalPages) {
            const pagination = document.getElementById('pagination');
            if (totalPages <= 1) { pagination.innerHTML = ''; return; }
            
            let html = `<button class="page-btn" data-page="${currentPage - 1}" ${currentPage === 1 ? 'disabled' : ''}>Previous</button>`;
            const startPage = Math.max(1, currentPage - 2);
            const endPage = Math.min(totalPages, currentPage + 2);
            
            if (startPage > 1) {
                html += `<button class="page-btn" data-page="1">1</button>`;
                if (startPage > 2) html += `<span style="padding:0 4px; color:#52525b;">…</span>`;
            }
            
            for (let i = startPage; i <= endPage; i++) {
                html += `<button class="page-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
            }
            
            if (endPage < totalPages) {
                if (endPage < totalPages - 1) html += `<span style="padding:0 4px; color:#52525b;">…</span>`;
                html += `<button class="page-btn" data-page="${totalPages}">${totalPages}</button>`;
            }
            
            html += `<button class="page-btn" data-page="${currentPage + 1}" ${currentPage === totalPages ? 'disabled' : ''}>Next</button>`;
            pagination.innerHTML = html;
        }

        document.getElementById('pagination').addEventListener('click', function(e) {
            if (e.target.classList.contains('page-btn')) {
                const targetPage = parseInt(e.target.getAttribute('data-page'));
                if (targetPage) loadRecords(targetPage);
            }
        });

        function sortTable(field) {
            if (sortField === field) {
                sortOrder = sortOrder === 'asc' ? 'desc' : 'asc';
            } else {
                sortField = field;
                sortOrder = 'desc';
            }
            document.querySelectorAll('th .sort-icon').forEach(el => el.textContent = '↕');
            const ths = document.querySelectorAll('th');
            const index = ['index', 'wsAccount', 'platformAccount', 'receptionist', 'ipStatus', 'joinDate', 'todayDeposit', 'monthDeposit', 'developer', 'senderName'].indexOf(field);
            if (index !== -1 && ths[index]) {
                ths[index].querySelector('.sort-icon').textContent = sortOrder === 'asc' ? '↑' : '↓';
            }
            if (currentQuery) searchRecords(); else loadRecords(1);
        }

        function openAddModal() {
            document.getElementById('modalTitle').textContent = 'Add Management Track Metric';
            document.getElementById('editId').value = '';
            document.getElementById('recordForm').reset();
            document.getElementById('formTodayDeposit').value = '0';
            document.getElementById('formMonthDeposit').value = '0';
            document.getElementById('formIpStatus').value = '正常';
            document.getElementById('saveBtn').textContent = 'Add Log Metric';
            document.getElementById('recordModal').classList.add('active');
        }

        function fetchAndEditRecord(id) {
            const target = recordsCached.find(r => r._id === id);
            if (target) {
                openEditModal(target);
            } else {
                fetch(`/api/records/${id}`)
                    .then(res => res.json())
                    .then(record => openEditModal(record))
                    .catch(() => showNotification('Error gathering contextual server object parameters.', 'error'));
            }
        }

        function openEditModal(record) {
            document.getElementById('modalTitle').textContent = 'Update Metrics Log Entry';
            document.getElementById('editId').value = record._id;
            document.getElementById('formWsAccount').value = record.wsAccount || '';
            document.getElementById('formPlatformAccount').value = record.platformAccount || '';
            document.getElementById('formTodayDeposit').value = record.todayDeposit || 0;
            document.getElementById('formMonthDeposit').value = record.monthDeposit || 0;
            document.getElementById('formJoinDate').value = record.joinDate || '';
            document.getElementById('formIpStatus').value = record.ipStatus || '正常';
            document.getElementById('formDeveloper').value = record.developer || '';
            document.getElementById('formReceptionist').value = record.receptionist || '';
            document.getElementById('formSenderName').value = record.senderName || '';
            document.getElementById('formRawMessage').value = record.rawMessage || '';
            document.getElementById('saveBtn').textContent = 'Apply Modified Parameters';
            document.getElementById('recordModal').classList.add('active');
        }

        function closeModal() { 
            document.getElementById('recordModal').classList.remove('active'); 
        }

        window.onclick = function(e) { 
            if (e.target === document.getElementById('recordModal')) closeModal(); 
        };

        function saveRecord(event) {
            event.preventDefault();
            
            const editId = document.getElementById('editId').value;
            const platformAccount = document.getElementById('formPlatformAccount').value.trim();
            
            if (!platformAccount) {
                showNotification('⚠️ Platform account is required!', 'error');
                return;
            }
            
            const data = {
                wsAccount: document.getElementById('formWsAccount').value.trim(),
                platformAccount: platformAccount,
                todayDeposit: parseInt(document.getElementById('formTodayDeposit').value) || 0,
                monthDeposit: parseInt(document.getElementById('formMonthDeposit').value) || 0,
                joinDate: document.getElementById('formJoinDate').value.trim(),
                ipStatus: document.getElementById('formIpStatus').value,
                developer: document.getElementById('formDeveloper').value.trim(),
                receptionist: document.getElementById('formReceptionist').value.trim(),
                senderName: document.getElementById('formSenderName').value.trim() || 'Admin',
                rawMessage: document.getElementById('formRawMessage').value.trim()
            };

            console.log('📤 Sending data:', data);

            const method = editId ? 'PUT' : 'POST';
            const url = editId ? `/api/records/${editId}` : '/api/records';

            fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => {
                if (!res.ok) {
                    return res.json().then(err => { throw new Error(err.error || 'Server error'); });
                }
                return res.json();
            })
            .then(result => {
                if (result.success) {
                    showNotification(result.message || 'Record saved successfully!', 'success');
                    closeModal();
                    if (currentQuery) {
                        searchRecords();
                    } else {
                        loadRecords(currentPage);
                    }
                } else {
                    showNotification('❌ Error: ' + (result.error || 'Unknown error'), 'error');
                }
            })
            .catch(err => {
                console.error('❌ Error saving record:', err);
                showNotification('❌ Error: ' + err.message, 'error');
            });
        }

        function deleteRecord(id) {
            if (confirm('Drop database tracking log structure row permanently? This cannot be reversed.')) {
                fetch(`/api/records/${id}`, { method: 'DELETE' })
                    .then(res => {
                        if (!res.ok) {
                            return res.json().then(err => { throw new Error(err.error || 'Server error'); });
                        }
                        return res.json();
                    })
                    .then(() => {
                        showNotification('Log entity removed from main table cluster layout maps.', 'success');
                        if (currentQuery) {
                            searchRecords();
                        } else {
                            loadRecords(currentPage);
                        }
                    })
                    .catch(err => {
                        console.error('Delete error:', err);
                        showNotification('Could not safely wipe transactional node target details: ' + err.message, 'error');
                    });
            }
        }

        function exportCSV() {
            let url = '/api/export/csv';
            if (currentQuery) {
                url += `?q=${encodeURIComponent(currentQuery)}&field=${currentField}`;
            }
            window.location.href = url;
        }

        function exportJSON() {
            let url = '/api/export/json';
            if (currentQuery) {
                url += `?q=${encodeURIComponent(currentQuery)}&field=${currentField}`;
            }
            window.location.href = url;
        }

        document.addEventListener('DOMContentLoaded', () => loadRecords(1));
    </script>
</body>
</html>
